# Hey Bradley — Phase 17 LLM provider env vars.
# Copy this file to .env.local for development. Never commit .env.local.
# Production builds MUST NOT have VITE_LLM_API_KEY set; vite.config.ts asserts.

# Provider: claude | gemini | simulated
VITE_LLM_PROVIDER=simulated

# Optional model id override (defaults to per-adapter default).
# VITE_LLM_MODEL=claude-haiku-4-5-20251001
# VITE_LLM_MODEL=gemini-2.5-flash

# DEV ONLY. Empty in production. Per ADR-043:
# - bundled into the dev server, never deployed.
# - production users supply their own key via the BYOK form in Settings.
VITE_LLM_API_KEY=

# Per-session USD cap (range 0.10–20.00, default 1.00).
VITE_LLM_MAX_USD=1.00
