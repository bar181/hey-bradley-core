          "props": {
            "text": "The AISP specification defines a universal JSON schema for describing websites. Instead of writing HTML, CSS, and JavaScript, you describe your site declaratively and the rendering engine handles the rest. This means faster iteration, easier maintenance, and zero vendor lock-in."
          }
        },
        {
          "id": "right",
          "type": "rich-text",
          "enabled": true,
          "order": 1,
          "props": {
            "text": "Every section, component, and style property is controlled through the config. Want to swap a hero variant from centered to split? Change one string. Want to add a pricing section? Drop in a new object. The schema validates your config at build time so you catch errors before they reach production."
          }
        }
      ],
      "content": {
        "heading": "How It Works",
        "subheading": "Declarative website generation from a single JSON file"
