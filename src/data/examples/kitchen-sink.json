        {
          "id": "left",
          "type": "rich-text",
          "enabled": true,
          "order": 0,
          "props": {
            "text": "Nexus Labs handles the undifferentiated heavy lifting of AI infrastructure. Instead of wrangling GPU clusters, building serving pipelines, and writing monitoring from scratch, your team focuses on the models and features that matter. We handle provisioning, scaling, and reliability."
          }
        },
        {
          "id": "right",
          "type": "rich-text",
          "enabled": true,
          "order": 1,
          "props": {
            "text": "Connect your model repository, define a deployment target, and push. Our CLI and SDK handle the rest: container packaging, load balancing, canary rollouts, and automatic rollback if latency spikes. Every deployment is versioned, reproducible, and auditable from day one."
          }
        }
      ],
      "content": {
        "heading": "How It Works",
        "subheading": "From model training to production serving in three commands"
      }
