        {
          "id": "q-1",
          "type": "faq-item",
          "enabled": true,
          "order": 0,
          "props": {
            "question": "What ML frameworks do you support?",
            "answer": "Nexus Labs supports PyTorch, TensorFlow, JAX, ONNX, and Hugging Face Transformers out of the box. Bring any model in a standard format and we handle containerization, optimization, and deployment automatically."
          }
        },
        {
          "id": "q-2",
          "type": "faq-item",
          "enabled": true,
          "order": 1,
          "props": {
            "question": "How does pricing work for inference?",
            "answer": "You pay per inference on the Starter and Pro plans, with generous monthly allowances included. Enterprise customers get volume discounts and committed-use pricing. There are never surprise bills — we alert you before you approach limits."
          }
        },
        {
          "id": "q-3",
          "type": "faq-item",
          "enabled": true,
