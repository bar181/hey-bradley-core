        {
          "id": "q-1",
          "type": "faq-item",
          "enabled": true,
          "order": 0,
          "props": {
            "question": "What is the AISP specification?",
            "answer": "AISP (AI Site Protocol) is a JSON schema that describes websites declaratively. Instead of writing code, you define sections, components, themes, and content in a structured format that any compatible renderer can interpret."
          }
        },
        {
          "id": "q-2",
          "type": "faq-item",
          "enabled": true,
          "order": 1,
          "props": {
            "question": "How many section types are supported?",
            "answer": "Currently 15 section types: menu, hero, columns, text, image, numbers, pricing, gallery, quotes, logos, team, questions, action, divider, and footer. Each has multiple variants for different visual styles."
          }
        },
        {
          "id": "q-3",
          "type": "faq-item",
          "enabled": true,
          "order": 2,
          "props": {
            "question": "Can I use custom themes?",
            "answer": "Absolutely. The theme object lets you control every visual aspect: palette colors, typography families, font sizes and weights, spacing, and border radius. You can also define alternate palettes for dark/light mode toggling."
          }
        },
        {
          "id": "q-4",
          "type": "faq-item",
          "enabled": true,
          "order": 3,
          "props": {
            "question": "Is there vendor lock-in?",
            "answer": "No. Your config is plain JSON that follows an open specification. Export it anytime and use it with any AISP-compatible renderer. Your content and structure are always yours."
          }
        }
      ],
      "content": {
        "heading": "Frequently Asked Questions",
        "subheading": "Everything you need to know about the platform"
      }
