        { "id": "t-1", "type": "testimonial", "enabled": true, "order": 0, "props": { "quote": "GreenLeaf helped us identify a $40M market opportunity we completely missed. Their strategic insight is unmatched.", "author": "Jennifer Walsh", "role": "CEO, NovaTech Industries", "rating": 5 } },
        { "id": "t-2", "type": "testimonial", "enabled": true, "order": 1, "props": { "quote": "Our operational costs dropped 30% in six months. The GreenLeaf team didn't just advise — they rolled up their sleeves and delivered.", "author": "Robert Nakamura", "role": "COO, Pacific Health Systems", "rating": 5 } },
        { "id": "t-3", "type": "testimonial", "enabled": true, "order": 2, "props": { "quote": "The best consulting engagement we've ever had. They challenged our assumptions and pushed us to think bigger about what was possible.", "author": "Amara Okafor", "role": "VP Strategy, Meridian Financial", "rating": 5 } }
