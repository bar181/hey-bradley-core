        {
          "id": "q-2",
          "type": "faq-item",
          "enabled": true,
          "order": 1,
          "props": {
            "question": "How much time do I need to commit each week?",
            "answer": "Self-paced students typically spend 10-15 hours per week. The full-time bootcamp requires 40+ hours per week for 12 weeks."
          }
        },
        {
          "id": "q-3",
          "type": "faq-item",
          "enabled": true,
          "order": 2,
          "props": {
            "question": "What languages and technologies will I learn?",
            "answer": "Our core curriculum covers JavaScript, TypeScript, React, Node.js, SQL, and Git. Advanced tracks add Python, cloud infrastructure, and system design."
          }
        },
        {
          "id": "q-4",
          "type": "faq-item",
          "enabled": true,
          "order": 3,
          "props": {
            "question": "Is there a money-back guarantee?",
            "answer": "Yes. If you complete the first two weeks and feel it's not for you, we'll refund 100% of your tuition — no questions asked."
          }
        },
        {
          "id": "q-5",
          "type": "faq-item",
          "enabled": true,
          "order": 4,
          "props": {
            "question": "Do you offer job placement support?",
