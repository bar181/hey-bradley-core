        { "id": "secondaryCta", "type": "button", "enabled": true, "order": 4, "props": { "text": "See How It Works", "url": "#about", "style": "ghost", "size": "lg" } },
        { "id": "heroImage", "type": "image", "enabled": false, "order": 5, "props": { "url": "", "alt": "", "aspect": "16:9" } },
