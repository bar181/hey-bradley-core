{
  "site": {
    "title": "Hey Bradley",
    "description": "A voice-first platform for building marketing websites",
    "author": "Bradley Ross",
    "email": "bar181@yahoo.com",
    "domain": "heybradley.com",
    "project": "hey-bradley",
    "version": "1.0.0-RC1",
    "spec": "aisp-1.2"
  },
  "theme": {
    "preset": "saas",
    "mode": "dark",
    "palette": {
      "bgPrimary": "#0a0a1a",
      "bgSecondary": "#12122a",
      "textPrimary": "#f8fafc",
      "textSecondary": "#94a3b8",
      "accentPrimary": "#6366f1",
      "accentSecondary": "#818cf8"
