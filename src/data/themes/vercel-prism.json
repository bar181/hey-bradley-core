{
  "theme": {
    "preset": "vercel-prism",
    "mode": "dark",
    "colors": {
      "primary": "#0070F3",
      "secondary": "#7928CA",
      "accent": "#FF0080",
      "background": "#000000",
      "surface": "#171717",
      "text": "#ffffff",
      "muted": "#888888",
      "border": "#333333"
    },
    "typography": {
      "fontFamily": "system-ui",
      "headingFamily": "system-ui",
      "headingWeight": 700,
