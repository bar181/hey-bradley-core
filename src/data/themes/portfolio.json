        {
          "id": "q-1",
          "type": "faq-item",
          "enabled": true,
          "order": 0,
          "props": {
            "question": "What is Hey Bradley?",
            "answer": "Hey Bradley is an AI-first website specification platform. Describe what you want, and it builds production-ready specs in real-time."
          }
        },
        {
          "id": "q-2",
          "type": "faq-item",
          "enabled": true,
          "order": 1,
          "props": {
            "question": "Do I need coding experience?",
            "answer": "No! Hey Bradley is designed for everyone. Our grandma test ensures even non-technical users can build beautiful websites."
          }
        },
        {
          "id": "q-3",
          "type": "faq-item",
          "enabled": true,
          "order": 2,
          "props": {
            "question": "What output formats are supported?",
            "answer": "Hey Bradley generates AISP specifications, JSON configurations, and will support HTML export in future versions."
          }
        },
        {
          "id": "q-4",
          "type": "faq-item",
          "enabled": true,
          "order": 3,
          "props": {
            "question": "Is there a free tier?",
            "answer": "Yes! The open core version is completely free with localStorage persistence. Pro features include cloud storage and advanced AI."
          }
        },
        {
          "id": "q-5",
          "type": "faq-item",
          "enabled": true,
          "order": 4,
          "props": {
            "question": "How does the AI work?",
            "answer": "Hey Bradley uses the AI Symbolic Protocol (AISP) to translate natural language into precise, machine-readable specifications with near-zero ambiguity."
          }
        }
      ]
