    "mood": "Editorial and readable",
    "heroVariant": "split-right"
  },
  "theme": {
    "preset": "blog",
    "mode": "light",
    "palette": {
      "bgPrimary": "#faf8f5",
      "bgSecondary": "#f0ebe3",
      "textPrimary": "#1c1917",
      "textSecondary": "#78716c",
      "accentPrimary": "#b45309",
      "accentSecondary": "#d97706"
    },
    "alternativePalettes": [
      { "name": "Sage", "bgPrimary": "#f6f7f4", "bgSecondary": "#ecede8", "textPrimary": "#1a2e1a", "textSecondary": "#6b7c6b", "accentPrimary": "#4d7c0f", "accentSecondary": "#65a30d" },
      { "name": "Rose", "bgPrimary": "#fff5f5", "bgSecondary": "#ffe4e6", "textPrimary": "#1c1917", "textSecondary": "#a1a1aa", "accentPrimary": "#be123c", "accentSecondary": "#e11d48" },
      { "name": "Slate", "bgPrimary": "#f8fafc", "bgSecondary": "#f1f5f9", "textPrimary": "#0f172a", "textSecondary": "#64748b", "accentPrimary": "#334155", "accentSecondary": "#475569" },
