        "direction": "row",
        "align": "center",
        "gap": "48px",
        "padding": "80px",
        "maxWidth": "1200px"
      },
      "style": {
        "background": "#faf8f5",
        "color": "#1c1917",
        "fontFamily": "DM Sans",
        "borderRadius": "0px"
      },
      "components": [
        { "id": "eyebrow", "type": "badge", "enabled": false, "order": 0, "props": { "text": "Hey Bradley 2.0 is Live", "icon": "sparkles" } },
        { "id": "headline", "type": "heading", "enabled": true, "order": 1, "props": { "text": "Build Websites by Just Talking", "level": 1, "size": "48px", "weight": 700 } },
        { "id": "subtitle", "type": "text", "enabled": true, "order": 2, "props": { "text": "Describe what you want, watch it appear in real-time, and get production-ready specs." } },
        { "id": "primaryCta", "type": "button", "enabled": true, "order": 3, "props": { "text": "Start Reading", "url": "#latest", "style": "filled", "size": "lg" } },
        { "id": "secondaryCta", "type": "button", "enabled": false, "order": 4, "props": { "text": "Subscribe", "url": "#subscribe", "style": "outline", "size": "lg" } },
        { "id": "heroImage", "type": "image", "enabled": true, "order": 5, "props": { "url": "https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=800&auto=format&q=80", "alt": "Writing workspace with coffee and laptop", "aspect": "16:9" } },
        { "id": "backgroundImage", "type": "image", "enabled": false, "order": 6, "props": {} },
        { "id": "heroVideo", "type": "video", "enabled": false, "order": 7, "props": {} },
        { "id": "trustBadges", "type": "trust", "enabled": false, "order": 8, "props": { "text": "", "show": false } }
      ]
    },
    {
      "type": "features",
      "id": "features-01",
      "enabled": true,
      "order": 1,
      "variant": "grid",
      "layout": { "display": "grid", "columns": 3, "gap": "32px", "padding": "64px 24px" },
      "style": { "background": "#f0ebe3", "color": "#1c1917" },
      "components": [
        { "id": "f1", "type": "feature-card", "enabled": true, "order": 0, "props": { "icon": "zap", "title": "Lightning Fast", "description": "Build and deploy in seconds, not days." } },
        { "id": "f2", "type": "feature-card", "enabled": true, "order": 1, "props": { "icon": "target", "title": "Precise Specs", "description": "AISP specifications with under 2% ambiguity." } },
        { "id": "f3", "type": "feature-card", "enabled": true, "order": 2, "props": { "icon": "shield", "title": "Enterprise Ready", "description": "Production-grade output from day one." } }
      ]
    },
    {
      "type": "cta",
      "id": "cta-01",
      "enabled": true,
      "order": 2,
      "variant": "simple",
      "layout": { "display": "flex", "direction": "column", "align": "center", "padding": "64px 24px", "gap": "16px" },
      "style": { "background": "#faf8f5", "color": "#1c1917" },
      "components": [
        { "id": "heading", "type": "heading", "enabled": true, "order": 0, "props": { "text": "Ready to build something amazing?", "level": 2, "size": "36px", "weight": 700 } },
        { "id": "subtitle", "type": "text", "enabled": true, "order": 1, "props": { "text": "Start building your next project with Hey Bradley." } },
        { "id": "button", "type": "button", "enabled": true, "order": 2, "props": { "text": "Launch Now", "url": "#signup", "style": "filled", "size": "lg" } }
      ]
    }
